# Server
PORT=8080

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:4321,http://localhost:3000

# SQLite
SQLITE_PATH=./data/portfolio.db

# LinkedIn API (optional — if empty, uses manual/static data)
LINKEDIN_ACCESS_TOKEN=

# Contact configuration
CONTACT_NOTIFICATION_EMAIL=hello@eduardobachmann.dev

# Rate limiting
RATE_LIMIT_CONTACT=10
RATE_LIMIT_GENERAL=60
